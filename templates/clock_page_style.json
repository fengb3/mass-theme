{
  "comment": "计时器页样式",
  "main_cont": { "bg_color": "0x000000" },
  "image_assets": [
    { "name": "clockpage_bg", "src": "/sdcard/themes/{{THEME_NAME}}/clock/bg.bin" },
    { "name": "btn_play", "src": "/sdcard/themes/{{THEME_NAME}}/clock/btn_play.bin" },
    { "name": "btn_pause", "src": "/sdcard/themes/{{THEME_NAME}}/clock/btn_pause.bin" }
  ],
  "font_assets": [
    { "name": "clockfont", "src": "/sdcard/themes/{{THEME_NAME}}/fonts/clockfont-48.bin" }
  ],
  "elements": [
    { "name": "clockpage_bg", "type": "img", "src": "clockpage_bg", "width": 480, "height": 480, "offset_x": 0, "offset_y": 0 },
    { "name": "clock_scale", "type": "clock", "width": 480, "height": 480, "marking_color": "0xFFFFFF", "marking_color_opa": 50, "marking_length": 100, "marking_width": 6 },
    { "name": "time_clock_label", "type": "label", "font": "clockfont", "color": "0xFFFFFF", "layout_align": "CENTER", "offset_x": 0, "offset_y": 0 },
    { "name": "play_btn", "type": "imgbtn", "width": 84, "height": 84, "offset_x": 198, "offset_y": 360, "states": { "released": "btn_play", "checked": "btn_pause" }, "on_click": "switchClockPause" }
  ]
}
