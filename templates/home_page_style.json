{
  "comment": "首页样式",
  "main_cont": {
    "bg_color": "0x000000"
  },
  "image_assets": [
    { "name": "homebg", "src": "/sdcard/themes/{{THEME_NAME}}/home/homebg.bin" },
    { "name": "homebg_blur", "src": "/sdcard/themes/{{THEME_NAME}}/home/homebg_blur.bin" },
    { "name": "muted_icon", "src": "/sdcard/themes/{{THEME_NAME}}/home/muted_icon.bin" },
    { "name": "caps_icon", "src": "/sdcard/themes/{{THEME_NAME}}/home/caps_icon.bin" },
    { "name": "music_icon_home", "src": "/sdcard/themes/{{THEME_NAME}}/home/music_icon.bin" },
    { "name": "muted_msg", "src": "/sdcard/themes/{{THEME_NAME}}/home/muted_msg.bin" },
    { "name": "volume_icon", "src": "/sdcard/themes/{{THEME_NAME}}/home/volume_icon.bin" },
    { "name": "light_icon", "src": "/sdcard/themes/{{THEME_NAME}}/home/light_icon.bin" }
  ],
  "font_assets": [
    { "name": "timefont", "src": "/sdcard/themes/{{THEME_NAME}}/fonts/timefont-64.bin" },
    { "name": "labelfont", "src": "/sdcard/themes/{{THEME_NAME}}/fonts/labelfont-16.bin" }
  ],
  "elements": [
    { "name": "homebg", "type": "img", "src": "homebg", "width": 480, "height": 480, "offset_x": 0, "offset_y": 0 },
    { "name": "time_label", "type": "label", "font": "timefont", "color": "0xFFFFFF", "layout_align": "TOP_RIGHT", "offset_x": -16, "offset_y": 21 },
    { "name": "week_label", "type": "label", "font": "labelfont", "color": "0xFFFFFF", "layout_align": "TOP_RIGHT", "offset_x": -16, "offset_y": 90 },
    { "name": "muted_icon", "type": "img", "src": "muted_icon", "width": 24, "height": 24, "offset_x": 16, "offset_y": 16 },
    { "name": "caps_icon", "type": "img", "src": "caps_icon", "width": 24, "height": 24, "offset_x": 48, "offset_y": 16 },
    { "name": "music_icon_home", "type": "img", "src": "music_icon_home", "width": 24, "height": 24, "offset_x": 80, "offset_y": 16 },
    { "name": "muted_msg", "type": "img", "src": "muted_msg", "width": 480, "height": 480, "offset_x": 0, "offset_y": 0 },
    { "name": "homebg_blur", "type": "img", "src": "homebg_blur", "width": 480, "height": 480, "offset_x": 0, "offset_y": 0 },
    { "name": "volume_bar", "type": "bar", "width": 160, "height": 408, "offset_x": 160, "offset_y": 36, "range_min": 0, "range_max": 100, "value": 50, "direction": "vertical", "main_color": "0x161616", "indic_color": "0x3F3F3F", "radius": 20, "padding": 8, "on_change": "onVolumeBarChange" },
    { "name": "volume_icon", "type": "img", "src": "volume_icon", "width": 24, "height": 24, "offset_x": 70, "offset_y": 430 },
    { "name": "volume_percent_label", "type": "label", "font": "labelfont", "color": "0xFFFFFF", "offset_x": 200, "offset_y": 430 },
    { "name": "volume_label", "type": "label", "font": "labelfont", "color": "0xFFFFFF", "text": "VOLUME", "offset_x": 200, "offset_y": 450 },
    { "name": "light_bar", "type": "bar", "width": 160, "height": 408, "offset_x": 160, "offset_y": 36, "range_min": 0, "range_max": 100, "value": 50, "direction": "vertical", "main_color": "0x161616", "indic_color": "0x3F3F3F", "radius": 20, "padding": 8, "on_change": "onLightBarChange" },
    { "name": "light_icon", "type": "img", "src": "light_icon", "width": 24, "height": 24, "offset_x": 70, "offset_y": 430 },
    { "name": "light_percent_label", "type": "label", "font": "labelfont", "color": "0xFFFFFF", "offset_x": 200, "offset_y": 430 },
    { "name": "light_label", "type": "label", "font": "labelfont", "color": "0xFFFFFF", "text": "LIGHT", "offset_x": 200, "offset_y": 450 }
  ]
}
