{
  "comment": "音乐页样式",
  "main_cont": { "bg_color": "0x000000" },
  "image_assets": [
    { "name": "musicbg", "src": "/sdcard/themes/{{THEME_NAME}}/music/bg.bin" },
    { "name": "btn_play", "src": "/sdcard/themes/{{THEME_NAME}}/music/btn_play.bin" },
    { "name": "btn_pause", "src": "/sdcard/themes/{{THEME_NAME}}/music/btn_pause.bin" }
  ],
  "font_assets": [
    { "name": "musicfont", "src": "/sdcard/themes/{{THEME_NAME}}/fonts/musicfont-24.bin" }
  ],
  "elements": [
    { "name": "cover", "type": "img", "src": "", "width": 480, "height": 480, "offset_x": 0, "offset_y": 0 },
    { "name": "song_title", "type": "label", "font": "musicfont", "color": "0xFFFFFF", "text": "Song Title", "width": 448, "offset_x": 16, "offset_y": 340 },
    { "name": "artist_name", "type": "label", "font": "musicfont", "color": "0xAAAAAA", "text": "Artist", "width": 448, "offset_x": 16, "offset_y": 370 },
    { "name": "musicSlider", "type": "slider", "range_min": 0, "range_max": 100, "value": 0, "knob_visible": false, "main_color": "0xD9D9D9", "indic_color": "0xFFFFFF", "radius": 10, "width": 448, "height": 12, "offset_x": 16, "offset_y": 372, "on_change": "onMusicSliderChange" },
    { "name": "play_btn", "type": "imgbtn", "width": 84, "height": 84, "offset_x": 198, "offset_y": 390, "states": { "released": "btn_play", "checked": "btn_pause" }, "on_click": "switchPlayPause" }
  ]
}
