{
  "comment": "计时结束页样式",
  "main_cont": { "bg_color": "0x000000" },
  "image_assets": [
    { "name": "timeup_bg", "src": "/sdcard/themes/{{THEME_NAME}}/clock/timeup_bg.bin" },
    { "name": "btn_goback", "src": "/sdcard/themes/{{THEME_NAME}}/clock/btn_goback.bin" }
  ],
  "font_assets": [
    { "name": "timeupfont", "src": "/sdcard/themes/{{THEME_NAME}}/fonts/timeupfont-32.bin" }
  ],
  "elements": [
    { "name": "timeup_bg", "type": "img", "src": "timeup_bg", "width": 480, "height": 480, "offset_x": 0, "offset_y": 0 },
    { "name": "timeup_time", "type": "label", "font": "timeupfont", "color": "0xFFFFFF", "layout_align": "CENTER", "offset_x": 0, "offset_y": -40 },
    { "name": "timeup_text", "type": "label", "font": "timeupfont", "color": "0xFFFFFF", "text": "TIME UP", "layout_align": "CENTER", "offset_x": 0, "offset_y": 20 },
    { "name": "timeup_goback", "type": "imgbtn", "width": 120, "height": 48, "offset_x": 180, "offset_y": 360, "states": { "released": "btn_goback" }, "on_click": "goBackToClockPage" }
  ]
}
